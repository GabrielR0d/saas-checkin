# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saascheckin

# --- Auth (REQUIRED: replace with a long random secret, min 32 chars) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS_DO_NOT_USE_THIS_VALUE
JWT_EXPIRES_IN=7d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- WhatsApp / Evolution API ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=evolution_key

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- CORS / Frontend ---
# In production set this to your exact frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5173

# --- Server ---
PORT=3001
NODE_ENV=production
